# ══════════════════════════════════════════════════════════════════
# Copy this file: cp .env.example .env
# Then fill in your actual keys.
# NEVER commit .env to Git — it's in .gitignore
# ══════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────
# OpenAI — powers all LLM nodes
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ── RECOMMENDED ──────────────────────────────────────────────────
# Tavily — best search for research agents, much better than DuckDuckGo
# Get at: https://tavily.com (free tier: 1000 searches/month)
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── OPTIONAL: LangSmith Observability ────────────────────────────
# Traces every node, every LLM call, every token — essential for production debugging
# Get at: https://smith.langchain.com (free tier available)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_your-langsmith-key-here
# LANGCHAIN_PROJECT=deep-research-agent
